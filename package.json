{
  "name": "mathgoal-platform",
  "version": "1.0.0",
  "description": "Mathgoal full-stack MVP: scraper ingestion, PostgreSQL API, and dashboard UI",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "migrate": "node scripts/migrate.js",
    "seed:python": "python scripts/scrape_to_postgres.py --ids-file collected_match_ids.json",
    "collect:ids:league": "python scripts/collect_match_ids_from_league.py"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0"
  }
}
